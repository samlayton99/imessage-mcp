# text-triage secrets — model keys + tokens. Copy to .env and fill in (`.env` is gitignored;
# never commit real values). Loaded at startup from ~/.text-triage/.env then ./.env.

# ── engine.provider: litellm ─ set whichever key(s) your engine.models use ──
ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GEMINI_API_KEY=

# ── engine.provider: agent_sdk ─ no key here ────────────────────────────────
# Uses your logged-in Claude Max session — run `claude setup-token` once.

# ── VPS (later) ─────────────────────────────────────────────────────────────
# TEXT_TRIAGE_VPS_INGEST_TOKEN=
# TEXT_TRIAGE_MCP_KEY=
